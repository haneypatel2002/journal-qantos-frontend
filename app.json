{
  "expo": {
    "name": "Punch",
    "slug": "punch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "punch",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "imageWidth": 500,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
            "backgroundColor": "#000000"
          }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.game.punchapp",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.game.punchapp",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18b75744-cd2f-46ab-a5ce-686a940f73a8"
      }
    },
    "owner": "haneyp123"
  }
}
